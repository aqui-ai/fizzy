<% @page_title = "Daily performance" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to reports_path, class: "btn btn--back btn--circle-mobile" do %>
      <%= icon_tag "arrow-left" %><strong class="overflow-ellipsis">Reports</strong>
    <% end %>
  </div>
  <h1 class="header__title" data-bridge--title-target="header"><%= @page_title %></h1>
<% end %>

<div class="reports margin-block-start-half">
  <p class="txt-subtle txt-align-center"><%= @date.strftime("%A, %B %-d") %></p>

  <section class="kpi-stats" aria-label="Compliance summary">
    <%= render "reports/stat", label: "Submitted", value: @submitted.size, tone: "positive" %>
    <%= render "reports/stat", label: "Late", value: @late.size %>
    <%= render "reports/stat", label: "Missing", value: @missing_count, tone: "negative" %>
    <%= render "reports/stat", label: "People", value: @users.size %>
  </section>

  <ul class="list-style-none flex flex-column gap margin-block-start-half">
    <% @users.each do |user| %>
      <% update = @updates[user.id] %>
      <% score = @scores[user] %>
      <li class="panel shadow center flex flex-column gap-half">
        <div class="flex justify-space-between align-center gap">
          <div class="flex align-center gap-half">
            <%= avatar_tag user %>
            <strong><%= user.name %></strong>
          </div>
          <div class="flex align-center gap">
            <% if update %>
              <%= render "daily_updates/status_badge", daily_update: update %>
            <% else %>
              <span class="txt-subtle txt-x-small txt-uppercase">No update</span>
            <% end %>
            <span class="txt-large font-weight-black"><%= score.total %></span>
          </div>
        </div>

        <ul class="list-style-none txt-small txt-subtle flex flex-column">
          <% score.reasons.each do |reason| %>
            <li class="flex justify-space-between gap">
              <span><%= reason.label %></span>
              <span class="txt-nowrap">+<%= reason.points %></span>
            </li>
          <% end %>
        </ul>
      </li>
    <% end %>
  </ul>
</div>
