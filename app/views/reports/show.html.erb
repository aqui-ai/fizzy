<% @page_title = "Reports" %>

<% content_for :header do %>
  <h1 class="header__title" data-bridge--title-target="header"><%= @page_title %></h1>
  <div class="header__actions header__actions--end">
    <%= link_to "Trends", reports_trend_path, class: "btn btn--circle-mobile" %>
  </div>
<% end %>

<div class="reports margin-block-start-half">
  <nav class="reports__ranges" aria-label="Date range">
    <% ReportsController::WINDOW_OPTIONS.each do |days| %>
      <%= link_to "#{days} days", reports_path(days: days),
            class: class_names("btn txt-small", "fill-selected" => @window_days == days),
            aria: { current: (@window_days == days ? "page" : nil) } %>
    <% end %>
  </nav>

  <section class="kpi-stats" aria-label="Card metrics">
    <%= render "reports/stat", label: "Open", value: @dashboard.card_metrics.open %>
    <%= render "reports/stat", label: "Overdue", value: @dashboard.card_metrics.overdue, tone: "negative" %>
    <%= render "reports/stat", label: "Due this week", value: @dashboard.card_metrics.due_this_week %>
    <%= render "reports/stat", label: "Unassigned", value: @dashboard.card_metrics.unassigned %>
    <%= render "reports/stat", label: "Not now", value: @dashboard.card_metrics.not_now %>
    <%= render "reports/stat", label: "Created", value: @dashboard.card_metrics.created_in_window %>
    <%= render "reports/stat", label: "Closed", value: @dashboard.card_metrics.closed_in_window, tone: "positive" %>
    <%= render "reports/stat", label: "Done total", value: @dashboard.card_metrics.done %>
    <%= render "reports/stat", label: "Avg open age", value: @dashboard.aging.average_open_age_in_days, unit: "d" %>
    <%= render "reports/stat", label: "Avg time to close", value: @dashboard.aging.average_time_to_close_in_days, unit: "d" %>
  </section>

  <div class="settings margin-block-start-half">
    <div class="settings__panel panel shadow center">
      <%= render "reports/breakdown", title: "Closed by board", data: @dashboard.throughput.by_board %>
    </div>
    <div class="settings__panel panel shadow center">
      <%= render "reports/breakdown", title: "Closed by assignee", data: @dashboard.throughput.by_assignee %>
    </div>
  </div>
</div>
