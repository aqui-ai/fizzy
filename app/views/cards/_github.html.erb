<% if card.published? && (card.github_linked? || card.account.github_integration.persisted?) %>
  <div class="card-github panel">
    <h3 class="card-github__label txt-x-small txt-uppercase txt-subtle">GitHub</h3>

    <div class="card-github__row">
      <span class="card-github__ref txt-small txt-subtle overflow-ellipsis" title="Card reference"><%= card.reference %></span>
      <%= button_to_copy_to_clipboard(card.git_branch_name) do %>
        <%= icon_tag "copy-paste" %>
        <span class="for-screen-reader">Copy git branch name</span>
      <% end %>
    </div>

    <% if issue = card.github_issue %>
      <div class="card-github__row">
        <%= link_to "#{issue.repository.full_name}##{issue.number}", issue.html_url, class: "txt-link overflow-ellipsis", target: "_blank", rel: "noopener" %>
        <%= github_state_tag issue.state %>
      </div>
    <% end %>

    <% card.github_pull_requests.order(:number).each do |pull_request| %>
      <div class="card-github__row">
        <%= link_to "PR ##{pull_request.number}", pull_request.html_url, class: "txt-link overflow-ellipsis", target: "_blank", rel: "noopener" %>
        <%= github_state_tag github_pull_request_state(pull_request) %>
      </div>
    <% end %>
  </div>
<% end %>
