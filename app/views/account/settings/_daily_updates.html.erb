<section class="settings__section">
  <header>
    <h2 class="divider">Daily updates</h2>
    <div>Everyone posts one update per work day. Set the cutoff after which an update counts as late, and whether weekends are excluded.</div>
  </header>

  <%= form_with model: Current.account, url: account_daily_update_policy_path, method: :patch, scope: :account, data: { controller: "form" }, class: "flex flex-column gap" do |form| %>
    <label class="flex flex-column gap-half">
      <strong>Cutoff time</strong>
      <%= form.select :daily_update_cutoff_hour,
            Account::DailyUpdatable::CUTOFF_HOURS.map { |hour| [ format("%02d:00", hour), hour ] },
            {}, class: "input input--select", disabled: !Current.user.admin? %>
    </label>

    <label class="flex align-center gap-half">
      <%= form.check_box :daily_update_exclude_weekends, class: "checkbox", disabled: !Current.user.admin? %>
      <span>Only require updates on weekdays</span>
    </label>

    <% if Current.user.admin? %>
      <%= form.button class: "btn btn--link align-self-start", data: { form_target: "submit" } do %>Save<% end %>
    <% end %>
  <% end %>
</section>
